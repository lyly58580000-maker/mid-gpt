# App
AUTH_SECRET=replace-with-64-char-random-string
AUTH_URL=http://localhost:3000

# Database（Vercel 生产环境必须用 PostgreSQL，推荐免费 Neon: https://neon.tech）
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Seed accounts
SEED_ADMIN_EMAIL=admin@sheyan.ai
SEED_ADMIN_PASSWORD=SheyanAdmin2026!
SEED_DEMO_EMAIL=demo@sheyan.ai
SEED_DEMO_PASSWORD=SheyanDemo2026!
SEED_DEMO_BALANCE=100

# QuickRouter 中转 API（OpenAI 兼容）
# 控制台：https://quickrouter.ai → 创建 API Key
TEXT_API_BASE_URL=https://api.quickrouter.ai/v1
TEXT_API_KEY=sk-your-quickrouter-key
TEXT_MODEL_NAME=gpt-5.5
TEXT_MAX_OUTPUT_TOKENS=4096
TEXT_CHARGE_POINTS=1

IMAGE_API_BASE_URL=https://api.quickrouter.ai/v1
IMAGE_API_KEY=sk-your-quickrouter-key
IMAGE_MODEL_NAME=gpt-image-2
IMAGE_SIZE=1024x1024
IMAGE_CHARGE_POINTS=5
